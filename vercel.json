{
  "version": 2,
  "builds": [
    {
      "src": "src/main/webapp/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/src/main/webapp/index.html"
    },
    {
      "src": "/games.html",
      "dest": "/src/main/webapp/games.html"
    },
    {
      "src": "/progress.html",
      "dest": "/src/main/webapp/progress.html"
    },
    {
      "src": "/css/(.*)",
      "dest": "/src/main/webapp/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/src/main/webapp/js/$1"
    },
    {
      "src": "/images/(.*)",
      "dest": "/src/main/webapp/images/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/src/main/webapp/$1"
    }
  ]
}